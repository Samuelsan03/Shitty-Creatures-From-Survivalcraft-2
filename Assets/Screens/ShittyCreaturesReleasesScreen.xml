<Screen xmlns="runtime-namespace:Game">
  <PanoramaWidget />
  <StackPanelWidget Direction="Horizontal">
    <CanvasWidget Style="{Widgets/TopBarContents}">
      <LabelWidget Name="TopBar.Label" Text="[ShittyCreaturesReleasesScreen:0]" />
    </CanvasWidget>
    <CanvasWidget Size="280, Infinity" Margin="10, 10">
      <BevelledRectangleWidget Style="{Styles/Area}" />
      <ListPanelWidget Name="ReleasesList" Direction="Vertical" Margin="5, 3" ItemSize="56" SelectionColor="10, 70, 0, 90" />
    </CanvasWidget>
    <CanvasWidget Size="Infinity, Infinity" Margin="10, 10">
      <BevelledRectangleWidget Style="{Styles/Area}" />
      <ScrollPanelWidget Name="ScrollPanel" Direction="Vertical" Margin="3, 3" ClampToBounds="true">
        <CanvasWidget HorizontalAlignment="Center" VerticalAlignment="Near">
          <StackPanelWidget Name="ReleaseInfoPanel" Direction="Vertical" HorizontalAlignment="Center" Margin="10, 10">
            <LabelWidget Name="ReleaseTitle" HorizontalAlignment="Center" TextAnchor="Center" WordWrap="true" FontScale="1.8" Color="255,255,255" />
            <CanvasWidget Size="0, 10" />
            <LabelWidget Name="ReleaseInfo" Color="180,180,180" HorizontalAlignment="Center" TextAnchor="Left" WordWrap="true" FontScale="0.9" />
            <CanvasWidget Size="0, 20" />
            <LabelWidget Name="ReleaseText" Color="220,220,220" HorizontalAlignment="Near" TextAnchor="Left" WordWrap="true" FontScale="0.95" />
          </StackPanelWidget>
        </CanvasWidget>
      </ScrollPanelWidget>
    </CanvasWidget>
  </StackPanelWidget>
</Screen>
