<CanvasWidget xmlns="runtime-namespace:Game" Margin="0,10">

    <CanvasWidget Size="700, 420" HorizontalAlignment="Center" VerticalAlignment="Center">

        <RectangleWidget FillColor="80, 80, 80, 255" OutlineColor="120, 120, 120, 160" OutlineThickness="2" />

        <StackPanelWidget Direction="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0, 5">

            <CanvasWidget Size="680, 360" Margin="10, 3">

                <RectangleWidget FillColor="0, 0, 0, 255" OutlineColor="20, 20, 20, 128" OutlineThickness="1" />

                <ScrollPanelWidget Name="ScrollPanel" Direction="Vertical" Margin="3, 3" ClampToBounds="true">
                    <CanvasWidget HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanelWidget Direction="Vertical" HorizontalAlignment="Center" Margin="10, 0">

                            <LabelWidget Name="Title" Text="[ShittyCreaturesAbout:Title]" Color="255,0,0" HorizontalAlignment="Center" FontScale="1.55" Margin="0,10" DropShadow="true"/>

                            <LabelWidget Name="Content" Text="[ShittyCreaturesAbout:Description]" Color="220,220,220" HorizontalAlignment="Center" TextAnchor="HorizontalCenter" WordWrap="true" FontScale="0.95" DropShadow="true" Margin="0,10"/>

                            <LabelWidget Name="CreatorTitle" Text="[ShittyCreaturesAbout:CreatorTitle]" Color="255,0,0" HorizontalAlignment="Center" FontScale="1.8" Margin="0,15" DropShadow="true"/>

                            <CanvasWidget Size="128,128" HorizontalAlignment="Center" Margin="0,10">
                                <RectangleWidget Size="128,128" HorizontalAlignment="Center" VerticalAlignment="Center" Subtexture="{Textures/Gui/samuelsan03}" FillColor="255,255,255" OutlineColor="0,0,0,0"/>
                            </CanvasWidget>

                            <LabelWidget Name="CreatorName" Text="[ShittyCreaturesAbout:CreatorName]" Color="220,220,220" HorizontalAlignment="Center" FontScale="1.0" Margin="0,5" DropShadow="true"/>

                            <LabelWidget Name="SocialTitle" Text="[ShittyCreaturesAbout:SocialTitle]" Color="255,0,0" HorizontalAlignment="Center" FontScale="1.2" Margin="0,5"/>

                            <StackPanelWidget Direction="Horizontal" HorizontalAlignment="Center" Margin="0,2">
                                <LabelWidget Name="YoutubeLabel" Text="[ShittyCreaturesAbout:YoutubeLabel]" Color="200,200,200" FontScale="0.9"/>
                                <LinkWidget Text="Samuelsan03" Url="https://www.youtube.com/channel/UC5LOqJu_SYQ-RjNNKW1-vXA" Color="100,150,255" FontScale="0.9"/>
                            </StackPanelWidget>

                            <StackPanelWidget Direction="Horizontal" HorizontalAlignment="Center" Margin="0,2">
                                <LabelWidget Name="TwitterLabel" Text="[ShittyCreaturesAbout:TwitterLabel]" Color="200,200,200" FontScale="0.9"/>
                                <LinkWidget Text="Samuelsan03" Url="https://x.com/oticananyo" Color="100,150,255" FontScale="0.9"/>
                            </StackPanelWidget>

                            <StackPanelWidget Direction="Horizontal" HorizontalAlignment="Center" Margin="0,2">
                                <LabelWidget Name="DiscordLabel" Text="[ShittyCreaturesAbout:DiscordLabel]" Color="200,200,200" FontScale="0.9"/>
                                <LabelWidget Text="samuelsan03" Color="100,150,255" FontScale="0.9"/>
                            </StackPanelWidget>

                            <StackPanelWidget Direction="Horizontal" HorizontalAlignment="Center" Margin="0,2">
                                <LabelWidget Name="BiliBiliLabel" Text="[ShittyCreaturesAbout:BiliBiliLabel]" Color="200,200,200" FontScale="0.9"/>
                                <LinkWidget Text="Samuelsan03" Url="https://space.bilibili.com/3546882976516701" Color="100,150,255" FontScale="0.9"/>
                            </StackPanelWidget>

                            <StackPanelWidget Direction="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                                <LabelWidget Name="ModPageLabel" Text="[ShittyCreaturesAbout:ModPageLabel]" Color="200,200,200" FontScale="0.9"/>
                                <LinkWidget Text="GitHub" Url="https://github.com/Samuelsan03/Shitty-Creatures-From-Survivalcraft-2" Color="100,150,255" FontScale="0.9"/>
                            </StackPanelWidget>

                            <LabelWidget Name="FinalMessage" Text="[ShittyCreaturesAbout:FinalMessage]" Color="255,200,100" HorizontalAlignment="Center" FontScale="0.95" Margin="0,15" WordWrap="true" DropShadow="true"/>

                        </StackPanelWidget>
                    </CanvasWidget>
                </ScrollPanelWidget>

            </CanvasWidget>

            <StackPanelWidget Direction="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <CanvasWidget Size="160, 50">
                    <BevelledButtonWidget Name="OkButton" Size="160, 50" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0, 3">
                        <RectangleWidget FillColor="100, 100, 100, 255" OutlineColor="120, 120, 120, 255"/>
                        <LabelWidget Name="ButtonLabel" Text="[ShittyCreaturesAbout:ExitButton]" Font="{Fonts/Pericles}" HorizontalAlignment="Center" VerticalAlignment="Center" Color="255, 255, 255, 255"/>
                    </BevelledButtonWidget>
                </CanvasWidget>
            </StackPanelWidget>

        </StackPanelWidget>

    </CanvasWidget>

</CanvasWidget>
