<CanvasWidget xmlns="runtime-namespace:Game" Size="614, 422">
  <BevelledRectangleWidget Size="614, 422" BevelSize="3" />
  
  <!-- Títulos -->
  <LabelWidget CanvasWidget.Position="12, 14" Name="PirateTraderTitle" Text="Pirate Trader" Color="255,255,255,192"/>
  <LabelWidget CanvasWidget.Position="306, 14" Name="InventoryTitle" Text="Inventory" Color="255,255,255,192"/>
  
  <!-- Grids de slots -->
  <GridPanelWidget CanvasWidget.Position="12, 52" Name="TraderGrid" ColumnsCount="4" RowsCount="2"/>
  <GridPanelWidget CanvasWidget.Position="306, 52" Name="InventoryGrid" ColumnsCount="4" RowsCount="4"/>
  
  <!-- Slot de monedas (izquierda) - igual que antes -->
  <CanvasWidget CanvasWidget.Position="12, 200" Size="68, 68">
    <LabelWidget Name="CoinSlotHint" Text="Coins" 
                 Color="128,128,128,255" FontScale="0.7"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 IsHitTestVisible="false" />
    <InventorySlotWidget Name="CoinSlot" Size="68, 68" />
  </CanvasWidget>
  
  <!-- Panel inferior izquierdo con label y botón (como en DispenserWidget) -->
  <CanvasWidget CanvasWidget.Position="12, 200" Size="288, 140">
    <StackPanelWidget Direction="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
      <LabelWidget Name="InfoLabel" Text="Select an item to buy." Color="255,255,0" HorizontalAlignment="Center"/>
      <CanvasWidget Size="0, 90" /> <!-- Espaciador -->
      <BevelledButtonWidget Name="BuyButton" Text="BUY" Style="{Styles/ButtonStyle_160x60}" HorizontalAlignment="Center" />
    </StackPanelWidget>
  </CanvasWidget>
</CanvasWidget>
