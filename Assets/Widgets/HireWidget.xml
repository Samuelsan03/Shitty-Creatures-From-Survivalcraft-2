<CanvasWidget xmlns="runtime-namespace:Game" Size="600, 400">
    <BevelledRectangleWidget BevelSize="3" CenterColor="0,0,0,200" BevelColor="128,128,128" />

    <StackPanelWidget Direction="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="30,30">
        <LabelWidget Name="HireTitleLabel" Color="255,255,255" FontScale="1.8" HorizontalAlignment="Center" />
        <CanvasWidget Size="0,15" />

        <LabelWidget Name="HireLoreLabel" Color="255,255,255" HorizontalAlignment="Center" WordWrap="true" FontScale="0.9" />
        <CanvasWidget Size="0,20" />

        <StackPanelWidget Direction="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <LabelWidget Name="HireInfoLabel" Color="255,255,255" FontScale="1.2" VerticalAlignment="Center" />
            <CanvasWidget Size="10,0" />
            <BlockIconWidget Name="CoinIcon" Size="32,32" VerticalAlignment="Center" />
        </StackPanelWidget>

        <CanvasWidget Size="0,25" />
        <BevelledButtonWidget Name="HireButton" FontScale="1.3" HorizontalAlignment="Center" Size="120,45" />
    </StackPanelWidget>
</CanvasWidget>
