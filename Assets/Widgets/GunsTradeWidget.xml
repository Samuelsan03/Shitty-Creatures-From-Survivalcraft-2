<CanvasWidget xmlns="runtime-namespace:Game" Size="614, 422">
  <BevelledRectangleWidget Size="614, 422" BevelSize="3" />
  
  <!-- Títulos -->
  <LabelWidget CanvasWidget.Position="12, 14" Name="GunsTraderTitle" Text="[GunsTraderWidget:Title]" Color="255,255,255,192"/>
  <LabelWidget CanvasWidget.Position="306, 14" Name="InventoryTitle" Text="[GunsTraderWidget:Inventory]" Color="255,255,255,192"/>
  
  <!-- Grids de slots -->
  <GridPanelWidget CanvasWidget.Position="12, 52" Name="TraderGrid" ColumnsCount="4" RowsCount="2"/>
  <GridPanelWidget CanvasWidget.Position="306, 52" Name="InventoryGrid" ColumnsCount="4" RowsCount="4"/>
  
  <!-- Slot de monedas -->
  <CanvasWidget CanvasWidget.Position="12, 200" Size="68, 68">
    <LabelWidget Name="CoinSlotHint" Text="[Trader:CoinSlotHint]" 
                 Color="128,128,128,255" FontScale="0.7"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 IsHitTestVisible="false" />
    <InventorySlotWidget Name="CoinSlot" Size="68, 68" />
  </CanvasWidget>
  
  <!-- Panel inferior izquierdo -->
  <CanvasWidget CanvasWidget.Position="12, 255" Size="288, 140">
    <!-- Información del ítem seleccionado (precio) -->
    <LabelWidget CanvasWidget.Position="10, 10"
                 Name="InfoLabel" 
                 Text="[Trader:SelectItemFirst]" 
                 Color="255,255,0"/>
    <!-- Temporizador de reabastecimiento (solo números) -->
    <LabelWidget CanvasWidget.Position="10, 35"
                 Name="TimerLabel"
                 Text="00:00"
                 Color="255,140,0"
                 FontScale="0.8"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"/>
    <BevelledButtonWidget CanvasWidget.Position="60, 70"
                          Name="BuyButton" 
                          Text="[Trader:BuyButton]" 
                          Style="{Styles/ButtonStyle_160x60}" />
  </CanvasWidget>
</CanvasWidget>
