<ComponentTemplate Name="ItemsLauncherShooterBehavior" Description="Comportamiento para NPCs que usan ItemsLauncher (AutoCannon) con animaciones de apuntado y recarga" Guid="36981492-9288-4f1a-a0ae-46ef5f5b9b90" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
