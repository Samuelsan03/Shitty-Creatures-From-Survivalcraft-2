    <Parameter Name="AutoNearbyCreaturesHelp" Value="true" Type="bool" Guid="912c89b2-caeb-4303-8abb-996c5b0c2b5f" Description="Si es true, llama a otros miembros de la manada cuando es atacado"/>
</ComponentTemplate>

<ComponentTemplate Name="ComponentBanditChase" Guid="c0b1cbec-0706-41cf-8bf4-9fd5647deca5" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3" Description="Componente de persecución mejorado para bandidos con ataques a todas las criaturas">
    <Parameter Name="Class" Value="Game.ComponentBanditChaseBehavior" Type="string" Guid="69363cb9-5c35-4d52-bff8-180338945516" Description="Nombre de la clase C# que implementa el comportamiento de persecución para bandidos"/>
    <Parameter Name="UpdateOrder" Value="100" Type="int" Guid="fd8bed30-b402-44be-a7f2-03c50676683f" Description="Orden de actualización del componente durante el ciclo del juego"/>
    <Parameter Name="LoadOrder" Value="80" Type="int" Guid="619e8331-7675-458b-bf8d-516c1409440a" Description="Orden de carga del componente en la entidad"/>
    <Parameter Name="DayChaseRange" Value="20" Type="float" Guid="34636b20-3970-4ce6-8e35-53a4af1d0ebb" Description="Rango de persecución durante el día (en unidades del juego)"/>
    <Parameter Name="NightChaseRange" Value="25" Type="float" Guid="76a02203-da67-4dea-a716-b2c5a50c599b" Description="Rango de persecución durante la noche (en unidades del juego)"/>
    <Parameter Name="DayChaseTime" Value="60" Type="float" Guid="11843324-ef21-43cb-a228-e8d33bd97528" Description="Tiempo máximo de persecución durante el día (en segundos)"/>
    <Parameter Name="NightChaseTime" Value="90" Type="float" Guid="08607584-29cc-4e5e-a10c-99a72e9ad0dd" Description="Tiempo máximo de persecución durante la noche (en segundos)"/>
    <Parameter Name="AutoChaseMask" Value="31" Type="int" Guid="4d1be3c7-d575-480e-9495-badfbb67068c" Description="Máscara de categorías de criaturas a perseguir (31 = todas las categorías)"/>
    <Parameter Name="ChaseNonPlayerProbability" Value="1.0" Type="float" Guid="3393f764-c0a5-4470-ae9a-f5a16586de4c" Description="Probabilidad de perseguir criaturas no jugador (1.0 = siempre)"/>
    <Parameter Name="ChaseWhenAttackedProbability" Value="1.0" Type="float" Guid="79b051bd-11bb-44c7-84e5-39d818a5e387" Description="Probabilidad de perseguir cuando es atacado (1.0 = siempre)"/>
    <Parameter Name="ChaseOnTouchProbability" Value="0.8" Type="float" Guid="c26518eb-905f-4342-a016-d6d7b9cecda1" Description="Probabilidad de perseguir al tocar (0.8 = 80% de probabilidad)"/>
    <Parameter Name="AttacksPlayer" Value="true" Type="bool" Guid="8113c60a-4f70-47cc-b8f7-abd920701ac5" Description="Si es true, ataca a jugadores (si HerdName no es 'player')"/>
