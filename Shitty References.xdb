        <ComponentTemplate Name="NewCreatureCollect" Description="Permite a la criatura recoger objetos automáticamente" Guid="e3793c3b-587f-43dd-a1e6-d2a6b4a28520" InheritanceParent="b05700ed-7e4e-4679-98f5-b597f421496b">
