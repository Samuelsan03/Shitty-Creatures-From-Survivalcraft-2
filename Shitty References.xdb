<ComponentTemplate Name="NewChaseBehavior" Description="Comportamiento de persecución mejorado con IA avanzada para protección del jugador, detección de amenazas durante noche y respuesta a ataques de la manada" Guid="1db20f99-32ba-4e7a-8e76-10686a2e76e5" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
  <Parameter Name="Class" Guid="387e61aa-98d5-47f5-b74e-4a0ddb3a645b" Value="Game.ComponentNewChaseBehavior" Type="string"/>
  <Parameter Name="DayChaseRange" Description="Rango de persecución durante el día" Guid="9d841aad-ecb7-49e6-95e2-c5530e18049e" Value="20" Type="float"/>
  <Parameter Name="NightChaseRange" Description="Rango de persecución durante la noche" Guid="ded5be34-959b-4e1b-9246-34bfba2fa58c" Value="25" Type="float"/>
  <Parameter Name="DayChaseTime" Description="Tiempo de persecución durante el día en segundos" Guid="e28083bc-c989-412b-8458-1b9d201a2967" Value="60" Type="float"/>
  <Parameter Name="NightChaseTime" Description="Tiempo de persecución durante la noche en segundos" Guid="7f5f2cf3-1d72-4ac6-b3bd-5162425e2b4e" Value="90" Type="float"/>
  <Parameter Name="ChaseWhenAttackedProbability" Description="Probabilidad de perseguir al ser atacado" Guid="055d0d94-39eb-4e77-a5c0-99ac3fbd52da" Value="0" Type="float"/>
  <Parameter Name="ChaseOnTouchProbability" Description="Probabilidad de perseguir al ser tocado por una criatura de AutoChaseMask" Guid="63590376-889c-4959-b586-fc58d5cc9bbf" Value="0" Type="float"/>
  <Parameter Name="AutoChaseMask" Description="Categorías de criaturas a perseguir automáticamente" Guid="5da7f87c-19be-463b-930e-57df04a0fd04" Value="LandPredator, LandOther, WaterPredator, WaterOther, Bird" Type="Game.CreatureCategory"/>
  <Parameter Name="ChaseNonPlayerProbability" Description="Probabilidad de perseguir objetivos no jugadores" Guid="0b3b2584-ce25-4c73-8269-cd1ebd5df44d" Value="1" Type="float"/>
  <Parameter Name="RangedAttackRange" Description="Rango de ataque a distancia (X = distancia mínima para melee, Y = distancia máxima para ranged)" Guid="e5aaebe5-378d-426e-98dc-dd6fcca09ecb" Value="5,20" Type="Vector2"/>
  <Parameter Name="DestroyBlocksWhenStuck" Description="Si está activado, la criatura destruirá bloques para liberarse cuando esté atascada durante más de 2 segundos" Guid="5b766c40-2a37-4027-9da1-c3218e109aa6" Value="false" Type="bool"/>
  <Parameter Name="PlaceBlocksWhenTargetHigh" Description="Si está activado, la criatura colocará bloques de tierra para alcanzar a su presa cuando esta se encuentre en una altura elevada (máximo 2 bloques verticales a la vez)" Guid="f6ffc52c-883d-4e29-a333-c413ccd864d7" Value="false" Type="bool"/>
  <Parameter Name="InvokeLightningOnHit" Description="Si está activado, la criatura invocará un rayo sobre el objetivo cada vez que realice un golpe cuerpo a cuerpo exitoso" Guid="9ffef00f-7ee4-4fec-b94c-24ac538f344a" Value="false" Type="bool"/>
  <Parameter Name="PushWhileAttacking" Description="Empuja al objetivo al golpear en cuerpo a cuerpo" Guid="51b107e6-f019-4b2b-a4f0-1e231b534d84" Value="false" Type="bool"/>
  <Parameter Name="ExplodeOnHit" Description="Provoca una explosión al golpear cuerpo a cuerpo" Guid="d1b75fea-9371-4af9-811f-85db7ff478b0" Value="false" Type="bool"/>
</ComponentTemplate>

<ComponentTemplate Name="NewHerdBehavior" Description="Comportamiento de manada mejorado con reconocimiento del jugador y protección entre aliados" Guid="24c8a629-49be-4cb4-b829-78d5a5a14204" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
  <Parameter Name="Class" Type="string" Value="Game.ComponentNewHerdBehavior" Guid="32cb08cf-154e-47f1-a070-13b6f1120a59"/>
  <Parameter Name="HerdName" Type="string" Value="player" Guid="1f0a8923-af89-45fc-bbdc-72eb4c1d0502" Description="Identificador de manada. Mismo valor = aliados. 'player' coopera con nombres que contengan 'guardian'. 'guardian' coopera con 'player' y no ataca al jugador."/>
  <Parameter Name="HerdingRange" Type="float" Value="32" Guid="4e45b0fd-79a6-48fb-9fbf-ca1564e43564" Description="Distancia máxima usada para buscar aliados al calcular el centro de la manada."/>
  <Parameter Name="AutoNearbyCreaturesHelp" Type="bool" Value="True" Guid="868cd214-1933-4259-9ddc-71f7c5ca334f" Description="Si está activo, la criatura pide ayuda al ser atacada y responde a ataques contra aliados cercanos."/>
  <Parameter Name="HelpCallRange" Type="float" Value="16" Guid="196c618a-8129-490f-a833-324e78429745" Description="Radio máximo en el que otras criaturas pueden responder a una llamada de ayuda."/>
  <Parameter Name="MaxHelpChaseTime" Type="float" Value="30" Guid="4300b7fe-6c5a-4654-981d-bedbc7055c66" Description="Tiempo máximo que una criatura ayudará persiguiendo al objetivo."/>
  <Parameter Name="AvoidAttackingSameHerd" Type="bool" Value="True" Guid="2d4f617d-0242-4293-ac89-42f75d853662" Description="Evita ataques contra miembros de la misma manada o aliados especiales."/>
</ComponentTemplate>
