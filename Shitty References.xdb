<Mod xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://gitee.com/THPRC/survivalcraft-api/raw/SCAPI1.8/Survivalcraft/Content/Assets/Database.xsd">
<Parameter Name="Class" Guid="9d071853-10cd-4208-9bdf-ffed6b5d5bdd" new-Value="Game.ComponentNewSleep" Type="string"/>
<Parameter Name="Class" Guid="3bb544e4-4e2b-4b31-9172-7709a9271366" new-Value="Game.ComponentNewHumanModel" Type="string"/>
<Parameter Name="Class" Guid="8c4f00ca-8f77-47c9-99bb-cefa4f94ee8d" new-Value="Game.ComponentNewVitalStats" Type="string"/>

    <Folder Name="Gameplay" Guid="d509e5e2-2c10-49f1-8223-85cd892c63b0">
    <ComponentTemplate Name="Healing" Description="Permite que una criatura cure a jugadores o criaturas amistosas de su manada cuando están heridos (salud menor al 30%). La criatura se moverá hacia el objetivo, realizará una animación de alimentación y restaurará su salud al 100%." Guid="636585cc-8eee-4fcb-b777-16f3e038e696" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
  <Parameter Name="CanHeal" Description="Activa la habilidad de curar. Si es false, la criatura no realizará ninguna acción de curación." Guid="5c2ccdf5-4418-479d-b0e1-a7968fe3854e" Value="false" Type="bool"/>
  <Parameter Name="Class" Description="Clase que implementa el comportamiento de curación en la criatura." Guid="a0810c74-e9b2-4e5c-bc3d-bf074914cedb" Value="Game.Healing" Type="string"/>
</ComponentTemplate>
    
    <ComponentTemplate Name="CoordinateDisplay" Description="Hace que se vea las coordenadas en pantalla del jugador" Guid="bd8323f8-399d-4acf-b96d-ed790ea2a6d7" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
    <Parameter Name="Class" Guid="91e9e7ee-3394-4f89-85ef-06f45f85c8dd" Value="Game.ComponentCoordinateDisplay" Type="string"/>
</ComponentTemplate>

    <ComponentTemplate Name="NewFlyAwayBehavior" Description="Comportamiento nulo. El bicho no huye por nada." Guid="a1cca7f2-9a15-4a07-9ab7-31bda890427e" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
          <Parameter Name="Class" Guid="b1371149-4d6e-464b-85a7-9a08731ee395" Value="Game.ComponentNewFlyAwayBehavior" Type="string"/>
        </ComponentTemplate>

    <ComponentTemplate Name="CreatureVomitBehavior" Description="Permite que una criatura realice un ataque especial escupiendo veneno o fuego hacia su objetivo cuando lo está persiguiendo." Guid="a91f3c5e-8c2d-4c1e-b7f4-6e2a9d3b7c11" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
  <Parameter Name="VomitShit" Description="Activa el vómito venenoso (daño tipo veneno)." Guid="b12c4a91-3f8d-4f4d-9d8c-1a2b3c4d5e61" Value="false" Type="bool"/>
  <Parameter Name="VomitFire" Description="Activa el vómito de fuego (daño tipo fuego)." Guid="c23d5b82-4e9f-5a6b-8c7d-2b3c4d5e6f72" Value="false" Type="bool"/>
  <Parameter Name="VomitFrozen" Description="Activa el vómito congelante (causa gripe, reduce temperatura y daño leve)." Guid="a78451cc-725e-4165-b091-6fdd3fa124fe" Value="false" Type="bool"/>
  <Parameter Name="VomitProbability" Description="Probabilidad por segundo de ejecutar el ataque de vómito cuando el objetivo está a distancia válida." Guid="d34e6c93-5f0a-6b7c-9d8e-3c4d5e6f7a83" Value="0.1" Type="float"/>
  <Parameter Name="VomitCooldown" Description="Tiempo mínimo en segundos entre cada uso del ataque de vómito." Guid="e45f7da4-6a1b-7c8d-0e9f-4d5e6f7a8b94" Value="5" Type="float"/>
  <Parameter Name="VomitDistanceRange" Description="Rango de distancia (mínima, máxima) en bloques a la que la criatura puede vomitar. Formato: X,Y donde X es la distancia mínima e Y la máxima." Guid="e93d0f52-5283-41f1-8fa2-9516d5c32b71" Value="2,12" Type="Vector2"/>
  <Parameter Name="Class" Description="Clase que implementa el comportamiento de vómito en la criatura." Guid="f56a8eb5-7b2c-8d9e-1f0a-5e6f7a8b9c05" Value="Game.ComponentCreatureVomit" Type="string"/>
</ComponentTemplate>

    <ComponentTemplate Name="VitalStats" Description="Handles creature vital stats, including hunger, thirst, stamina, sleep, temperature and wetness" Guid="4f2ad7cc-d19a-4d64-99eb-5c6ca2b7a7b3" InheritanceParent="b05700ed-7e4e-4679-98f5-b597f421496b">
  <ParameterSet Name="Satiation" Description="Contains satiation for each food item index" Guid="18e05ebe-9421-4169-9469-83f926f14af3"/>
  <Parameter Name="Stamina" Description="Stamina level, 0 to 1" Guid="6e113066-4b9b-4f7f-be54-cfd7dc91e97f" Value="1" Type="float"/>
  <Parameter Name="Wetness" Description="Wetness, 0 to 1" Guid="cbe6401e-253d-4ef3-94a1-dc52e476c90e" Value="0" Type="float"/>
  <Parameter Name="Food" Description="Amount of food, 0 to 1" Guid="20eacb65-b947-4613-9a01-31df75cef42c" Value="1" Type="float"/>
  <Parameter Name="Class" Guid="1d7f533f-0295-4df4-be0c-70a9d27ce65b" Value="Game.ComponentNewVitalStats" Type="string"/>
  <Parameter Name="Sleep" Description="Sleep level, 0 to 1" Guid="69e3578f-48ee-4fe1-b9af-c46b099a7328" Value="1" Type="float"/>
  <Parameter Name="Temperature" Description="Body temperature, in world temperature units" Guid="93b62c67-e897-431b-992d-13f2f8015006" Value="12" Type="float"/>
  <Parameter Name="Thirst" Description="Water/Thirst level, 0 to 1" Guid="f0878cb9-d7b8-458d-99f9-35e88fa29b5a" Value="1" Type="float"/>
</ComponentTemplate>

    <ComponentTemplate Name="RageZombieBehavior" Description="Hace que el zombi entre en furia con poca salud, aumentando su velocidad, atacando sin demora y mostrando ojos brillantes." Guid="2d584a55-7ccb-42c7-8fc0-c3f288eefae9" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
    <Parameter Name="Class" Guid="e4fb314e-1a7a-43ae-afde-69d0033eabc1" Value="Game.ComponentRageZombieBehavior" Type="string"/>
</ComponentTemplate>

    <ComponentTemplate Name="DefensiveRunAwayBehavior" Description="Versión de ComponentRunAwayBehavior que solo huye cuando es atacado, ignorando ruidos y salud baja." Guid="fd28cb72-1c75-4a8e-920e-3cd1457ee6e1" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
    <Parameter Name="LowHealthToEscape" Description="Umbral de salud para huir (no utilizado en esta versión)" Guid="75069ae7-c5bc-4990-8249-2f44632aca2e" Value="0.3" Type="float"/>
    <Parameter Name="Class" Guid="bed3ec74-af04-408d-b1dd-9c2b20bb7a1d" Value="Game.ComponentDefensiveRunAwayBehavior" Type="string"/>
</ComponentTemplate>

    <ComponentTemplate Name="Sleep" Description="Handles sleeping of the creature entity" Guid="585d2fc1-f523-459a-9cb3-8fafa9fbadbd" InheritanceParent="b05700ed-7e4e-4679-98f5-b597f421496b">
          <Parameter Name="SleepStartTime" Description="Time when creature went to sleep, or 0 if not sleeping" Guid="8fd03c34-cd99-410c-8bc4-14dc0acbfb2a" Value="0" Type="double"/>
          <Parameter Name="Class" Guid="6e461b52-3ea8-4164-b053-12270b61fdea" Value="Game.ComponentNewSleep" Type="string"/>
          <Parameter Name="AllowManualWakeUp" Description="Whether manual wakeup is allowed" Guid="a1283ce3-e15f-4a6b-a2c4-7db18befcb98" Value="False" Type="bool"/>
        </ComponentTemplate>

    <ComponentTemplate Name="HireableNPC" Description="Permite contratar a la criatura con monedas nucleares" Guid="4582a365-6082-4260-a7ba-35d141cddbbd" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
    <Parameter Name="Class" Guid="e0bca7bc-5f06-4b64-a8c9-bfd6d0267b9e" Value="Game.ComponentHireableNPC" Type="string"/>
    <Parameter Name="HirePrice" Description="Precio en monedas nucleares para contratar" Guid="6cb5c4eb-8db6-453a-bc52-452ae6b4e1ee" Value="100" Type="int"/>
</ComponentTemplate>

<ComponentTemplate Name="Trader" Description="Permite que una criatura actúe como comerciante pirata. Se puede abrir interactuando con ella para comprar objetos usando NuclearCoin." Guid="7753c16f-a467-4624-be61-3a048cb51cf0" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
    <Parameter Name="SlotsCount" Description="Número de ranuras del inventario del comerciante." Guid="c6ee570b-66e7-4a61-ac7b-db306d0fe316" Value="8" Type="int"/>
    <Parameter Name="ActiveSlotIndex" Description="Índice de la ranura activa (por defecto 0, no se usa en este componente pero se mantiene por herencia)." Guid="5c2ceace-8cf9-45fb-b1d3-c64c6c41d298" Value="0" Type="int"/>
    <Parameter Name="TradeItems" Description="Lista de objetos que el comerciante puede vender. Formato: 'BlockName:probability:price:maxCount[:variant]'. probability es el peso usado para seleccionar el objeto durante el reabastecimiento. price es el precio por unidad en NuclearCoin. maxCount es la cantidad máxima que aparecerá en el slot. variant es opcional y permite especificar la variante de bloque (por ejemplo diferentes tipos de madera, tela, etc.). Ejemplos: 'MusketBlock:0.5:50:1,RepeatCrossbowBlock:0.3:120:1,AmmoBlock:0.2:5:20' o 'ClothingBlock:0.4:30:1:5'." Guid="4c0c5d62-bf60-480a-8296-8aa76cfeacf1" Value="MusketBlock:1:50:1" Type="string"/>
    <Parameter Name="RestockInterval" Description="Intervalo en segundos de tiempo de juego entre reabastecimientos." Guid="daa4d12b-d73f-4005-871b-34af37d243d3" Value="300" Type="double"/>
    <Parameter Name="Class" Value="Game.ComponentTrader" Type="string"/>
</ComponentTemplate>

    <ComponentTemplate Name="FluInfected" Description="Componente que aplica los efectos de la gripe a una criatura. Reduce la velocidad de movimiento (hasta 20% en casos graves) y provoca tos periódica con sonido y alerta de ruido." Guid="4301cca7-d3dd-4e09-ab45-eed3ff27e6aa" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
    <Parameter Name="FluDuration" Description="Duración actual de la infección en segundos. Se actualiza automáticamente durante el juego." Guid="95bac8b6-ed74-41fa-88ae-92b79a127ba8" Value="0" Type="float"/>
    <Parameter Name="FluResistance" Description="Resistencia de la criatura a la gripe. Este valor se resta de la duración al recibir una nueva infección." Guid="2b015c53-331c-453c-ba60-b1c92974b6e4" Value="0" Type="float"/>
    <Parameter Name="CoughSound" Description="Ruta(s) de sonido para la tos. Pueden ser múltiples separadas por punto y coma (;). Ej: 'Audio/Creatures/FemaleCough/FemaleCough1;Audio/Creatures/MaleCough/MaleCough1'" Guid="b163d080-1394-48c8-89d3-baf952bdbec6" Value="Audio/Creatures/FemaleCough/FemaleCough1" Type="string"/>
    <Parameter Name="SneezeSound" Description="Ruta(s) de sonido para el estornudo. Pueden ser múltiples separadas por punto y coma (;). Ej: 'Audio/Creatures/FemaleSneeze/FemaleSneeze1;Audio/Creatures/MaleSneeze/MaleSneeze1'" Guid="10780f97-b39f-40c2-9c14-7ce06b803db7" Value="Audio/Creatures/FemaleSneeze/FemaleSneeze1" Type="string"/>
    <Parameter Name="Class" Guid="c43950db-c658-4ca5-a98c-1391d5d7bdf7" Value="Game.ComponentFluInfected" Type="string"/>
</ComponentTemplate>

<ComponentTemplate Name="FluInfectBehavior" Description="Comportamiento que permite a una criatura infectar a su objetivo con gripe durante el ataque. Utiliza ComponentChaseBehavior para obtener el objetivo y aplica probabilidad configurable de infección." Guid="248005bf-3528-4f3d-bec4-1f3f7e84900c" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
    <Parameter Name="FluIntensity" Description="Duración en segundos de la gripe que se aplicará a la víctima. Valores recomendados: 300 (5 minutos) para infección estándar." Guid="ab238ba7-71b0-4d55-8c92-5ad6b4ad9191" Value="300" Type="float"/>
    <Parameter Name="InfectProbability" Description="Probabilidad (0.0 a 1.0) de que un ataque exitoso infecte al objetivo. 1.0 = 100% de probabilidad." Guid="be20bf44-9ef2-46ce-9b50-a7fa13af7934" Value="1.0" Type="float"/>
    <Parameter Name="Class" Guid="d56674d6-c37a-4b47-93f8-3ebc221e4bf1" Value="Game.ComponentFluInfectBehavior" Type="string"/>
</ComponentTemplate>

<ComponentTemplate Name="NewSteedBehavior" Description="Versión mejorada de SteedBehavior SIN restricción de silla de montar. Controla el comportamiento de montura: movimientos, velocidad, giros y búsqueda de jinetes. Se habilita/deshabilita con el parámetro IsEnabled." Guid="03268b67-f4e7-49dd-99f4-2b0301e3b2c1" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
    <Parameter Name="IsEnabled" Description="Habilita o deshabilita este comportamiento. A diferencia del original, NO depende de que el nombre de la entidad termine en '_Saddled'." Guid="1363e234-f948-4e5d-b24a-8824ae6bd707" Value="True" Type="bool"/>
    <Parameter Name="Class" Guid="d6954ee2-466c-4f88-9a01-e2b2e77e9255" Value="Game.ComponentNewSteedBehavior" Type="string"/>
</ComponentTemplate>

<ComponentTemplate Name="NewDumpRiderBehavior" Description="Versión mejorada de DumpRiderBehavior SIN restricción de silla de montar. Controla cuándo la criatura intenta tirar al jinete (comportamiento salvaje, carrera ciega, estupor). Por defecto deshabilitado (IsEnabled=false) para evitar que las criaturas tiren al jinete." Guid="deb33f45-0de2-4ceb-8e1e-f2bcf0fb177e" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
    <Parameter Name="IsEnabled" Description="Habilita o deshabilita este comportamiento. A diferencia del original, NO depende de que el nombre de la entidad termine en '_Saddled'. Se recomienda False para criaturas domadas." Guid="2ffef809-14ea-4114-94fc-360a0904b4f3" Value="False" Type="bool"/>
    <Parameter Name="Class" Guid="720f1e33-592b-498e-a759-a76d13b231ec" Value="Game.ComponentNewDumpRiderBehavior" Type="string"/>
</ComponentTemplate>

<ComponentTemplate Name="NewStubbornSteedBehavior" Description="Versión mejorada de StubbornSteedBehavior SIN restricción de silla de montar. Controla la terquedad de la montura: se niega a moverse cuando tiene hambre. Ahora configurable con probabilidad y habilitación independiente del nombre de la entidad." Guid="e131e1ac-1866-41b4-9795-2f8bd5f87112" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
    <Parameter Name="IsEnabled" Description="Habilita o deshabilita este comportamiento. A diferencia del original, NO depende de que el nombre de la entidad termine en '_Saddled'." Guid="c8acd931-6cbb-4e91-93e8-22a8f3b9e487" Value="True" Type="bool"/>
    <Parameter Name="StubbornProbability" Description="Probabilidad (0-1) de que la criatura se vuelva terca cuando tiene hambre. Por defecto 0.5 (50%)." Guid="cbeb2cde-1d97-4625-84c5-06cd686cb2b0" Value="0.5" Type="float"/>
    <Parameter Name="StubbornEndTime" Description="Tiempo (en segundos de juego) hasta que termina la terquedad. Se guarda automáticamente." Guid="6a6357e1-b5a3-43c2-9880-a4a08451295c" Value="0" Type="double"/>
    <Parameter Name="Class" Guid="7d564db9-f444-4616-bb29-bacc6e2203a2" Value="Game.ComponentNewStubbornSteedBehavior" Type="string"/>
</ComponentTemplate>

<ComponentTemplate Name="NewMount" Description="Versión mejorada de Mount que trabaja con ComponentNewRider. Maneja los puntos de montaje/desmontaje." Guid="ba0e138c-fe06-4b83-a405-503e03843493" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
    <Parameter Name="DismountOffset" Description="Offset de la posición de desmontaje respecto al punto de montura (eje X se refleja en ambos lados)" Guid="34c3f58a-fb79-4785-98bf-a768cd15ccb2" Value="0,0,0" Type="Vector3"/>
    <Parameter Name="MountOffset" Description="Offset del punto de montaje" Guid="bf6c8df0-f2f3-4de4-accb-a2482e531c04" Value="0,0,0" Type="Vector3"/>
    <Parameter Name="MountAllowToStartRange" Description="Distancia máxima para permitir comenzar a montar" Guid="409586d1-8e4b-49cc-b443-9be2be27e0c8" Value="2.5" Type="float"/>
    <Parameter Name="Class" Guid="71c28373-2eb3-4eab-bbad-a1419779ed28" Value="Game.ComponentNewMount" Type="string"/>
</ComponentTemplate>

<ComponentTemplate Name="NewRider" Description="Versión mejorada de Rider que trabaja con ComponentNewMount. Permite montar criaturas domesticadas." Guid="abb28eb0-a4a0-4ab4-ac3d-2ba3a42dc88b" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
    <Parameter Name="RiderOffset" Description="Desplazamiento local de la posición del jinete respecto al punto de montura" Guid="64fa6130-a33a-423b-8579-b5b6cde60208" Value="0,-0.71,0" Type="Vector3"/>
    <Parameter Name="Class" Guid="d5880224-096d-4a58-982c-86756e12670f" Value="Game.ComponentNewRider" Type="string"/>
</ComponentTemplate>

<ComponentTemplate Name="BoomerExplosion" Description="Comportamiento que hace que el Boomer explote al morir, con configuración de daño, radio y efectos incendiarios." Guid="bf245bcc-8786-4839-9528-87f3f7ff4833" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
    <Parameter Name="Class" Guid="a3967efb-2f42-48c0-af6d-d2d133469681" Value="Game.ComponentBoomerExplosion" Type="string"/>
    <Parameter Name="ActivationRange" Description="Distancia a la que el Boomer detecta al jugador para activarse (actualmente no se usa, la explosión es solo por muerte)" Guid="ffb2f590-7aaa-4195-9892-8558be629e76" Value="3" Type="float"/>
    <Parameter Name="UseStandardExplosion" Description="Indica si se debe usar la explosión estándar del juego (con presión)" Guid="1caef662-17e4-4aa5-be7b-064c196b4514" Value="true" Type="bool"/>
    <Parameter Name="UseCustomShockwave" Description="Indica si se debe usar la onda expansiva personalizada (daño y empuje a entidades)" Guid="d95f1324-bcbd-4b27-bba3-a588b2681a6f" Value="false" Type="bool"/>
    <Parameter Name="ExplosionPressure" Description="Presión de la explosión estándar. Afecta el daño a bloques y entidades." Guid="2a413648-c81e-42cf-9802-cf10daca4fef" Value="80" Type="float"/>
    <Parameter Name="IsIncendiary" Description="Determina si la explosión prende fuego a los bloques circundantes." Guid="812d187b-fc8d-4f2a-81c6-ad1d0a153291" Value="false" Type="bool"/>
    <Parameter Name="ExplosionRadius" Description="Radio total de la explosión. Afecta el alcance de las explosiones secundarias escaladas." Guid="0de2cf52-1dae-40cf-9bb4-56f4c4ea1239" Value="10" Type="float"/>
    <Parameter Name="BlockDamageRadius" Description="Radio en el que se dañan o destruyen los bloques por la onda personalizada." Guid="c7bff956-433d-4a85-90e4-5d6c664678f1" Value="8" Type="float"/>
    <Parameter Name="EntityDamageRadius" Description="Radio en el que las entidades reciben daño por la onda personalizada." Guid="87f94ade-17f5-4902-8a8a-ffc590799d60" Value="10" Type="float"/>
    <Parameter Name="ShockwaveDamage" Description="Cantidad de daño base que causa la onda expansiva personalizada a las entidades." Guid="830909b9-1ee9-44f5-9c9f-d620f95c6961" Value="100" Type="float"/>
    <Parameter Name="ShockwaveForce" Description="Fuerza de empuje de la onda expansiva personalizada sobre las entidades." Guid="fba7b351-8b23-4d28-8c30-d8bdf1a9a1c5" Value="50" Type="float"/>
    <Parameter Name="DestroyBlocks" Description="Si la onda personalizada debe destruir bloques (requiere UseCustomShockwave=true)." Guid="e9abf1f6-38d4-4f05-a9b2-6fda78fab3f7" Value="true" Type="bool"/>
    <Parameter Name="PreventExplosion" Description="Si es true, evita que el Boomer explote al morir. Útil para depuración o estados especiales." Guid="743b92f5-2f46-4bb6-bb8e-1b24c5c7f210" Value="false" Type="bool"/>
</ComponentTemplate>

<ComponentTemplate Name="BoomerFireExplosion" Description="Comportamiento para un Boomer incendiario. Explota al morir, causa daño y propaga fuego." Guid="aeba3d06-e20a-4a04-bd51-ae8d5b2d03c0" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
    <Parameter Name="Class" Guid="a51dc7a0-3313-4d63-843f-bd667c5e3137" Value="Game.ComponentBoomerFireExplosion" Type="string"/>
    <Parameter Name="ActivationRange" Description="Distancia de activación (no usado, la explosión es por muerte)" Guid="4c5ded94-60d4-421f-96c2-677461c03c67" Value="3" Type="float"/>
    <Parameter Name="UseStandardExplosion" Description="Usar la explosión estándar del juego." Guid="4bebf7b4-2e57-4d82-b543-039bb4147aca" Value="true" Type="bool"/>
    <Parameter Name="UseCustomShockwave" Description="Usar onda expansiva personalizada." Guid="4a39c103-eaf8-4c0f-92a9-ffbd091a2d01" Value="false" Type="bool"/>
    <Parameter Name="ExplosionPressure" Description="Presión de la explosión." Guid="4ff5b265-bfa7-417d-beec-790bbb53a002" Value="80" Type="float"/>
    <Parameter Name="IsIncendiary" Description="Si la explosión es incendiaria. Por defecto es true." Guid="6df9da3e-82f3-4246-b5af-994e1530dd9c" Value="true" Type="bool"/>
    <Parameter Name="ExplosionRadius" Description="Radio de la explosión." Guid="d94dae61-0788-45ac-8f41-79b02d8e71b5" Value="10" Type="float"/>
    <Parameter Name="BlockDamageRadius" Description="Radio de daño a bloques." Guid="74060485-9b97-47ba-b47c-ab3066081669" Value="8" Type="float"/>
    <Parameter Name="EntityDamageRadius" Description="Radio de daño a entidades." Guid="bbe2d5f8-eaa5-46a5-b660-333e8e30ecc7" Value="10" Type="float"/>
    <Parameter Name="ShockwaveDamage" Description="Daño base de la onda." Guid="7dec45d4-eff2-4c3a-a5b5-90a48ec4ee12" Value="100" Type="float"/>
    <Parameter Name="ShockwaveForce" Description="Fuerza de empuje." Guid="e69308a2-660c-4da5-91b3-8cee27de9615" Value="50" Type="float"/>
    <Parameter Name="DestroyBlocks" Description="Destruir bloques." Guid="4496ef05-0025-4a25-93d9-feb83ad36c36" Value="true" Type="bool"/>
    <Parameter Name="FireSpreadChance" Description="Probabilidad (0-1) de que un bloque cercano se incendie." Guid="90a2f76c-b813-48ec-9d73-ccf7961dcd19" Value="0.4" Type="float"/>
    <Parameter Name="FireDuration" Description="Duración del fuego en segundos." Guid="19059953-365b-4f83-8c02-4b732766e974" Value="10" Type="float"/>
    <Parameter Name="PreventExplosion" Description="Prevenir la explosión." Guid="10347c1f-141a-45e2-8c3c-4b787eb34ca2" Value="false" Type="bool"/>
</ComponentTemplate>

