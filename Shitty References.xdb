<ComponentTemplate Name="ZombieHerdBehavior" Description="Comportamiento de manada especializado para zombis. Permite coordinación avanzada de ataques, llamadas de ayuda inteligentes, agrupamiento agresivo opcional, y lógica especial para evitar conflictos internos." Guid="384dbb1e-8baf-4880-9e86-db1ef0b51169" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
  <Parameter Name="Class" Guid="032d3df1-890c-41cd-8c2a-a73a68906936" Value="Game.ComponentZombieHerdBehavior" Type="string"/>
  <Parameter Name="HerdName" Description="Nombre identificador de la manada zombi. Las criaturas con el mismo nombre se considerarán parte del mismo grupo." Guid="ac893ef1-7d7b-4d53-b989-8496abaeec48" Value="Zombie" Type="string"/>
  <Parameter Name="CallForHelpWhenAttacked" Description="Determina si el zombi llamará a otros miembros de la misma manada cuando sea atacado por un enemigo externo." Guid="fb4dac70-e765-4e73-bcd3-97480e5f2dda" Value="true" Type="bool"/>
  <Parameter Name="HelpCallRange" Description="Distancia máxima en la que otros zombis pueden escuchar el llamado de ayuda y unirse al ataque." Guid="ca7449d9-27d9-4fcf-a263-0d72261baf4d" Value="25" Type="float"/>
  <Parameter Name="HelpChaseTime" Description="Tiempo máximo en segundos durante el cual los zombis ayudarán persiguiendo al objetivo." Guid="7c455a06-7ac2-4f7e-ad47-8009210d3520" Value="30" Type="float"/>
  <Parameter Name="IsPersistentHelp" Description="Define si la ayuda es persistente. Si está activado, los zombis no abandonarán fácilmente la persecución." Guid="54dcde1d-b9ae-4c44-8b3f-a075542c8a1d" Value="false" Type="bool"/>
  <Parameter Name="ZombieAggressiveGrouping" Description="Permite comportamiento de agrupamiento agresivo. Los zombis deambulan más, coordinan ataques ampliados, y reaccionan con mayor intensidad." Guid="566fce20-d5ba-4aba-a3b6-c642e9cbed47" Value="false" Type="bool"/>
  <Parameter Name="HerdingRange" Description="Rango máximo utilizado para calcular el centro de la manada y mantener cohesión entre zombis." Guid="6898f15e-13d4-46ad-8e91-af685f0ed817" Value="40" Type="float"/>
  <Parameter Name="AutoNearbyCreaturesHelp" Description="Indica si se usa la lógica automática base para que criaturas cercanas ayuden, además del sistema personalizado de zombis." Guid="df490040-8e49-4e64-b397-c6fd485ee04b" Value="true" Type="bool"/>
</ComponentTemplate>

<ComponentTemplate Name="ZombieChaseBehavior" Description="Comportamiento avanzado de persecución para zombis. Permite retaliación inteligente contra el último atacante, coordinación con la manada, huida estratégica ante conflictos internos, y agresividad forzada durante la Noche Verde." Guid="1a05e72e-fd6b-4eb3-b72b-59e530c4c7b9" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
  <Parameter Name="Class" Guid="29dc27cf-cf34-44f4-a9c4-48ac4cdf90b3" Value="Game.ComponentZombieChaseBehavior" Type="string"/>
  <Parameter Name="AttacksSameHerd" Description="Permite que el zombi ataque a miembros de su misma manada. Si está desactivado, los ignorará como objetivos normales, aunque podrá retaliar si es atacado." Guid="9dcbbba0-2ec1-4b7e-80c2-87bd8a778eb6" Value="false" Type="bool"/>
  <Parameter Name="AttacksAllCategories" Description="Define si el zombi puede atacar todas las categorías de criaturas. Incluye depredadores terrestres, criaturas acuáticas, aves, y jugadores." Guid="9a85d9e3-9082-4990-a468-80a967657d84" Value="true" Type="bool"/>
  <Parameter Name="FleeFromSameHerd" Description="Indica si el zombi debe huir cuando es atacado por un miembro de su misma manada. No depende del nivel de salud." Guid="2f04e645-4411-4d58-a3bc-6423586842e1" Value="true" Type="bool"/>
  <Parameter Name="FleeDistance" Description="Distancia mínima que el zombi intentará mantener cuando entra en estado de huida. Se mide en bloques." Guid="e9284f30-1492-4480-96ac-9878891dac20" Value="10" Type="float"/>
  <Parameter Name="ForceAttackDuringGreenNight" Description="Si está activado, el zombi forzará comportamiento agresivo contra jugadores durante la Noche Verde. Al terminar la Noche Verde, volverá inmediatamente a su comportamiento normal." Guid="9389f01b-5184-4d5d-a1c9-a04df8409f83" Value="false" Type="bool"/>
</ComponentTemplate>

<ComponentTemplate Name="NewAutoInteract" Guid="0d193534-6d05-4939-bba8-4a8755d3b064" InheritanceParent="31894441-d90a-4549-9264-db9dbe20e234" Description="Componente que permite a NPCs interactuar automáticamente con bloques como puertas y rejillas">
