            <Parameter Name="SpecificBlocks" Description="Bloques específicos que la criatura puede romper/colocar." Guid="5545bf1b-3fd7-4951-9748-c20fa1e87cfc" Value="" Type="string"/>
            <Parameter Name="UseFromInventory" Description="La criatura verifica si tiene bloques en su inventario para colocar si el valor es true, de lo contrario la criatura podrá colocar bloques infinitamente si el valor es false." Guid="549f2cff-8688-4b9f-849e-8f7f78a7f2a6" Value="False" Type="bool"/>
            <Parameter Name="BreakProbability" Description="Probabilidad para que la criatura rompa un bloque en el momento, si el valor es 1, siempre romperá bloques todo el tiempo" Guid="55e537a2-04d1-4802-8448-026a4ce27681" Value="1" Type="float"/>
