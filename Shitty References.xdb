<ComponentTemplate Name="NewRunAwayBehavior" Description="Comportamiento que hace que la criatura huya solo cuando su salud es crítica (ignora ruidos)" Guid="0a320e99-fd38-4e3f-a5cf-d3e789235213" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
