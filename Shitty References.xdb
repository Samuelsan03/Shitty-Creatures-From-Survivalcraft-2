  <Parameter Name="LowHealthToEscape" Description="Umbral de salud por debajo del cual la criatura empieza a huir (ej: 0.33 = 33% de vida)" Guid="3c0b1b0f-5e3c-464a-aa85-a1f013711f3e" Value="0.33" Type="float"/>
</ComponentTemplate>

        <ComponentTemplate Name="PathBreaker" Guid="c1b4a3e9-6f0e-4b5d-8a7c-1f9d2e8a7b6c" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
            <Parameter Name="CanBreakBlocks" Description="La criatura puede romper bloques si el valor es true." Guid="4992bbe3-770e-4fe5-a977-40e8608428db" Value="False" Type="bool"/>
